# Normalize line endings to LF across all platforms
* text=auto eol=lf

# Source code
*.py        text eol=lf diff=python
*.pyi       text eol=lf diff=python
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.html      text eol=lf
*.html.j2   text eol=lf
*.css       text eol=lf
*.sh        text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf
Caddyfile*  text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.heic      binary
*.pdf       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.gpg       binary
