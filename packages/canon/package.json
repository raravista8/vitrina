{
  "name": "@samosite/canon",
  "version": "0.12.0",
  "description": "Canonical UI for Самосайт — single source of truth for visual design. 0.12.0 «Витрина v5»: глобальный ребренд токенов «Фарфор и лак» (бордо/винный accent #7A2B34, тёплый фарфор, radius 0 + без теней на уровне токенов, дисплей Sofia Sans Condensed) — перекрашивает все модули; новый лендинг V5_* (@samosite/canon/landing: Header/Hero/Story/Examples+SiteViewer/HowItWorks/Reviews/Pricing/Honest/Faq/FinalCta/Footer, реестры EXAMPLES/FAQ_ITEMS) — Hero без инпута, controlled onIntake(entry); интейк v2 In2_* (@samosite/canon/intake, NICHE_LIB_V2). Старые v3-лендинг и S3_*/SubmitModal — byte-identical. Изменение значений токенов — заявленное исключение из additive (ребренд).",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./landing": {
      "types": "./dist/landing/index.d.ts",
      "import": "./dist/landing/index.js"
    },
    "./intake": {
      "types": "./dist/intake/index.d.ts",
      "import": "./dist/intake/index.js"
    },
    "./customer": {
      "types": "./dist/customer/index.d.ts",
      "import": "./dist/customer/index.js"
    },
    "./admin-demo": {
      "types": "./dist/admin-demo/index.d.ts",
      "import": "./dist/admin-demo/index.js"
    },
    "./admin-core": {
      "types": "./dist/admin-core/index.d.ts",
      "import": "./dist/admin-core/index.js"
    },
    "./admin-ops": {
      "types": "./dist/admin-ops/index.d.ts",
      "import": "./dist/admin-ops/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./source": {
      "types": "./dist/source/index.d.ts",
      "import": "./dist/source/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}