{
  "name": "@samosite/canon",
  "version": "0.13.0",
  "description": "Canonical UI for Самосайт — single source of truth for visual design. 0.13.0 «Фидбек v2»: vote-first S9_FeedbackModal удалён (breaking, без депрекейта); новый модуль @samosite/canon/feedback — одна модалка FeedbackV2Modal, два режима (blocker: причина отказа уходящего посетителя + оффер бесплатного черновика; question: личный канал вопросов, «отвечаю лично»), controlled, REASONS = enum консьерж-таблицы 1:1, data-fb-* хуки. Токены «Фарфор и лак» и прочие модули (лендинг v5/v3, интейк In2_*/S3_*, customer S7/S8, admin-*) — byte-identical.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./landing": {
      "types": "./dist/landing/index.d.ts",
      "import": "./dist/landing/index.js"
    },
    "./intake": {
      "types": "./dist/intake/index.d.ts",
      "import": "./dist/intake/index.js"
    },
    "./customer": {
      "types": "./dist/customer/index.d.ts",
      "import": "./dist/customer/index.js"
    },
    "./feedback": {
      "types": "./dist/feedback/index.d.ts",
      "import": "./dist/feedback/index.js"
    },
    "./admin-demo": {
      "types": "./dist/admin-demo/index.d.ts",
      "import": "./dist/admin-demo/index.js"
    },
    "./admin-core": {
      "types": "./dist/admin-core/index.d.ts",
      "import": "./dist/admin-core/index.js"
    },
    "./admin-ops": {
      "types": "./dist/admin-ops/index.d.ts",
      "import": "./dist/admin-ops/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./source": {
      "types": "./dist/source/index.d.ts",
      "import": "./dist/source/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
