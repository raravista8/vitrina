{
  "name": "@samosite/canon",
  "version": "0.1.0",
  "description": "Canonical UI for Самосайт — single source of truth for visual design. Drop-in React components that match canon/index.html byte-for-byte.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./tokens": {
      "import": "./dist/tokens.js"
    },
    "./primitives": {
      "import": "./dist/primitives/index.js"
    },
    "./landing": {
      "import": "./dist/landing/index.js"
    },
    "./intake": {
      "import": "./dist/intake/index.js"
    },
    "./customer": {
      "import": "./dist/customer/index.js"
    },
    "./admin-demo": {
      "import": "./dist/admin-demo/index.js"
    },
    "./admin-core": {
      "import": "./dist/admin-core/index.js"
    },
    "./admin-ops": {
      "import": "./dist/admin-ops/index.js"
    },
    "./source": {
      "import": "./dist/source/index.js"
    },
    "./tailwind-preset": {
      "import": "./dist/tailwind-preset.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
