# Vitrina production Caddyfile (T2.4).
#
# Topology:
#   - Caddy terminates TLS for samosite.online + *.samosite.online
#   - samosite.online / www.samosite.online   → landing container (Next.js SSR)
#   - <anything>.samosite.online /api/*    → api container
#   - <anything>.samosite.online /*        → CDN-fronted Object Storage
#                                         (customer static sites)
#
# Wildcard cert is issued out-of-band by the acme.sh sidecar (see
# infra/acme/) via Let's Encrypt DNS-01 against Selectel DNS. The cert
# lives in a shared volume mounted at /etc/caddy/certs/. The sidecar
# auto-renews ≤30 days before expiry — Caddy reloads when /etc/caddy/
# certs/.reload-trigger touches change (handled by an external watcher,
# or `docker compose exec caddy caddy reload` once a day; see README).
{
	# Disable automatic HTTPS provisioning — we manage certs externally.
	auto_https off
	# Persist /data/caddy across container restarts (mounted volume).
	storage file_system {
		root /data/caddy
	}
}

# ---- Global security headers (SECURITY.md A02) -----------------------------

(security_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
		-Server
	}
}

# ---- Shared wildcard cert snippet ------------------------------------------

(wildcard_tls) {
	tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/key.pem
}

# ---- Landing (samosite.online root) ------------------------------------------

samosite.online, www.samosite.online {
	import wildcard_tls
	import security_headers

	# Landing CSP — allows Yandex Metrika + SmartCaptcha.
	header Content-Security-Policy "default-src 'self'; script-src 'self' https://mc.yandex.ru https://smartcaptcha.yandexcloud.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://mc.yandex.ru https://storage.yandexcloud.net; connect-src 'self' https://mc.yandex.ru; frame-src https://smartcaptcha.yandexcloud.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

	reverse_proxy landing:3000 {
		header_up X-Real-IP {remote_host}
	}
}

# ---- Wildcard *.samosite.online ----------------------------------------------

*.samosite.online {
	import wildcard_tls
	import security_headers

	@api path /api/*
	handle @api {
		header Content-Security-Policy "default-src 'self'; script-src 'self' https://smartcaptcha.yandexcloud.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://storage.yandexcloud.net; connect-src 'self' https://smartcaptcha.yandexcloud.net; frame-src https://smartcaptcha.yandexcloud.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		reverse_proxy api:8000 {
			header_up X-Real-IP {remote_host}
		}
	}

	handle {
		# Customer static sites — Caddy proxies Object Storage. In
		# production Selectel CDN normally sits in front, but Caddy
		# remains a working origin for direct-VPS hits.
		@root path /
		rewrite @root /index.html
		# Prefix every path with the leftmost subdomain (labels.2 of the
		# host) so the upstream sees the bucket prefix in the URL.
		rewrite * /{labels.2}{uri}
		reverse_proxy {$STATIC_ORIGIN_URL} {
			header_up Host {$STATIC_ORIGIN_HOST}
		}
	}
}

# ---- HTTP redirect + load-balancer health probe ----------------------------

:80 {
	@healthz path /healthz
	handle @healthz {
		respond "ok" 200
	}
	redir https://{host}{uri}
}
