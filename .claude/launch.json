{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Landing (Next.js dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "landing", "run", "dev"],
      "port": 3000
    },
    {
      "name": "Backend API (FastAPI / uvicorn --reload)",
      "runtimeExecutable": "poetry",
      "runtimeArgs": [
        "--directory",
        "backend",
        "run",
        "uvicorn",
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "port": 8000
    },
    {
      "name": "Full stack (docker compose)",
      "runtimeExecutable": "make",
      "runtimeArgs": ["dev"],
      "port": 8000
    }
  ]
}
