# Vitrina — example environment variables.
# Copy to `.env` for local dev. Never commit `.env`.
# All secrets in production live in Docker secrets, not in this file.
# See SECURITY.md §5 for the secret-management model.

# ---- App ---------------------------------------------------------------------
ENVIRONMENT=development        # development | staging | production
DEBUG=true                     # MUST be false in production (Settings validator enforces)
APP_BASE_URL=http://localhost:8000
LANDING_BASE_URL=http://localhost:3000
SITES_BASE_DOMAIN=vitrina.site
LOG_LEVEL=DEBUG                # DEBUG only in dev; INFO+ in prod

# ---- Postgres ----------------------------------------------------------------
# Three application roles are created by infra/postgres/init/01_roles.sh on
# first container boot. POSTGRES_USER below is the *bootstrap migrator* — a
# superuser that runs CREATE TABLE / GRANT statements from Alembic. The app
# runtime connects as `vitrina_app` (DML only, no DDL) per SECURITY.md T4.2.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vitrina
POSTGRES_USER=vitrina_migrator
POSTGRES_PASSWORD=migrator_change_in_prod
VITRINA_APP_PASSWORD=app_change_in_prod
VITRINA_READONLY_PASSWORD=readonly_change_in_prod
VITRINA_AUDIT_WRITER_PASSWORD=audit_change_in_prod
DATABASE_URL=postgresql+asyncpg://vitrina_app:app_change_in_prod@postgres:5432/vitrina  # pragma: allowlist secret
ALEMBIC_DATABASE_URL=postgresql+psycopg://vitrina_migrator:migrator_change_in_prod@postgres:5432/vitrina  # pragma: allowlist secret

# ---- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- Crypto (generate fresh keys; never reuse across envs) -------------------
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JOB_HMAC_KEY=
SESSION_SECRET_KEY=
BACKUP_PASSPHRASE=

# ---- Admin (bootstrap via `make seed-admin`) ---------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=           # bcrypt hash, NEVER plaintext
ADMIN_TOTP_SECRET=             # base32 from pyotp.random_base32()

# ---- Yandex services ---------------------------------------------------------
YANDEXGPT_FOLDER_ID=
YANDEXGPT_API_KEY=
YANDEX_GEOSEARCH_API_KEY=
YANDEX_SMARTCAPTCHA_CLIENT_KEY=
YANDEX_SMARTCAPTCHA_SERVER_KEY=
YANDEX_WEBMASTER_API_KEY=
YANDEX_ID_CLIENT_ID=
YANDEX_ID_CLIENT_SECRET=

# ---- Object Storage (Yandex S3-compatible) -----------------------------------
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=vitrina-prod
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Telegram (notifications + parser bot) -----------------------------------
TG_BOT_TOKEN=
TG_ADMIN_CHAT_ID=
TG_PARSER_BOT_USERNAME=VitrinaIntakeBot

# ---- MAX (feature-flagged, see ADR-0008) -------------------------------------
FEATURE_MAX_BOT=false
MAX_BOT_TOKEN=

# ---- SMS provider (SMS.ru or Yandex Cloud Notify — see OQ-A7) ----------------
SMS_PROVIDER=smsru             # smsru | yandex
SMS_API_KEY=
SMS_SENDER=Vitrina

# ---- SMTP (transactional email) ----------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vitrina.site

# ---- Google Search Console (T2.6) --------------------------------------------
GSC_SERVICE_ACCOUNT_JSON=      # path to JSON keyfile inside container, or empty to disable

# ---- Observability -----------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Rate limits -------------------------------------------------------------
RATE_LIMIT_APPLICATIONS_PER_IP_PER_HOUR=3
RATE_LIMIT_LEADS_PER_IP_PER_HOUR=3
RATE_LIMIT_LEADS_PER_IP_PER_DAY=10
RATE_LIMIT_PREVIEW_PER_IP_PER_MIN=10
