{% extends "_layout.html.j2" %}
{% block title %}{{ doc.t or doc.num }} — {{ site.title }}{% endblock %}
{% block description %}{{ doc.org }} {{ doc.num }} от {{ doc.d }}{% if doc.t %} — {{ doc.t }}{% endif %}{% endblock %}
{% block canonical_path %}{{ doc.slug_path }}{% endblock %}
{% set active = 'docs' %}
{% block head_extra %}<script type="application/ld+json">{{ jsonld_article | tojson }}</script>{% endblock %}

{% block main %}
<section class="page-head">
  <div class="wrap">
    <div class="breadcrumb"><a href="index.html">Главная</a> / <a href="docs.html">Документы</a> / {{ doc.num }}</div>
    <div class="eyebrow">{{ doc.org }} · {{ doc.num }} · {{ doc.d }}</div>
    <h1>{{ doc.t | nbsp }}</h1>
  </div>
</section>

<section class="content">
  <div class="wrap-narrow">
    {% if doc.header %}
    <div class="map-frame" style="padding:clamp(20px,3vw,36px);text-align:center">
      {% for line in doc.header %}
      <div class="mono" style="font-size:13px;letter-spacing:0.04em;color:var(--ink-2);line-height:1.7">{{ line }}</div>
      {% endfor %}
    </div>
    {% endif %}

    <div id="doc-body" style="margin-top:clamp(20px,3vw,30px)">{{ doc.body | rich }}</div>

    <div class="rule-star"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l9 9-9 9-9-9z"/></svg></div>
    <a class="btn btn-ghost" href="docs.html">← Все документы</a>
  </div>
</section>
{% endblock %}
