{% extends "_layout.html.j2" %}
{% block title %}Схема — {{ site.title }}{% endblock %}
{% block description %}Карта железнодорожных линий и схемы путевого развития станций, разъездов и блок-постов бывшего СССР.{% endblock %}
{% block canonical_path %}railmap.html{% endblock %}
{% set active = 'railmap' %}

{% block main %}
{% set ns = namespace(total=0) %}
{% for g in directory %}{% set ns.total = ns.total + (g['items'] | length) %}{% endfor %}
<section class="page-head">
  <div class="wrap">
    <div class="breadcrumb"><a href="index.html">Главная</a> / Схема</div>
    <div class="eyebrow">Раздел 01</div>
    <h1>Карта линий и схемы станций</h1>
    <p class="ph-sub">{{ "Справочник станций, разъездов и блок-постов бывшего СССР. Отфильтруйте по дороге и типу или найдите по названию — по щелчку открывается схема путевого развития, фотографии и историческая справка." | nbsp }}</p>
  </div>
</section>

<section class="content">
  <div class="wrap">
    <div class="section-head">
      <div><div class="eyebrow" style="margin-bottom:10px">Справочник</div><h2>Станции и раздельные пункты</h2></div>
      <div class="sh-meta" id="dir-count">показано: {{ ns.total }} из {{ ns.total }}</div>
    </div>

    <div class="filters" id="dir-filters">
      <span class="fl-label">Дорога</span>
      <button class="chip active" data-f="road" data-v="all">Все</button>
      {% for g in directory %}<button class="chip" data-f="road" data-v="{{ g.road }}">{{ g.road }}</button>{% endfor %}

      <span class="fl-label" style="margin-left:14px">Тип</span>
      <button class="chip active" data-f="kind" data-v="all">Все</button>
      <button class="chip" data-f="kind" data-v="ст.">Станции</button>
      <button class="chip" data-f="kind" data-v="рзд.">Разъезды</button>
      <button class="chip" data-f="kind" data-v="о.п.">Остановочные</button>

      <input class="fl-search" id="dir-search" type="search" placeholder="Найти станцию…" aria-label="Поиск станции" style="margin-left:14px" />
    </div>

    <div class="road-cols" id="dir">
      {% for g in directory %}
      <div class="road-col" data-road="{{ g.road }}">
        <div class="road-col-head"><h3>{{ g.road }}</h3><span>{{ g.region }}</span></div>
        <ul class="st-list">
          {% for item in g['items'] %}
          <li data-name="{{ item[0] | lower }}" data-kind="{{ item[1] }}"><a href="{{ item[2] | station_url }}"><span class="st-kind">{{ item[1] }}</span> <span class="st-name">{{ item[0] }}</span></a></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>
    <div class="dir-empty" id="dir-empty" style="display:none">По выбранным фильтрам станций не найдено</div>
  </div>
</section>
{% endblock %}

{% block body_end %}
<script>
// Interactive station directory. Rows are server-rendered (crawlable); JS only
// shows/hides by road + kind + name search and keeps the "показано N из M" count.
(function () {
  var state = { road: 'all', kind: 'all', q: '' };
  var cols = [].slice.call(document.querySelectorAll('#dir .road-col'));
  var items = [].slice.call(document.querySelectorAll('#dir .st-list li'));
  var countEl = document.getElementById('dir-count');
  var emptyEl = document.getElementById('dir-empty');
  var total = items.length;

  function apply() {
    var q = state.q.trim().toLowerCase();
    var shown = 0;
    items.forEach(function (li) {
      var road = li.closest('.road-col').dataset.road;
      var ok = (state.road === 'all' || road === state.road)
        && (state.kind === 'all' || li.dataset.kind === state.kind)
        && (q === '' || (li.dataset.name || '').indexOf(q) !== -1);
      li.style.display = ok ? '' : 'none';
      if (ok) shown++;
    });
    // hide a road column when none of its items are visible
    cols.forEach(function (col) {
      var any = [].slice.call(col.querySelectorAll('.st-list li'))
        .some(function (li) { return li.style.display !== 'none'; });
      col.style.display = any ? '' : 'none';
    });
    if (emptyEl) emptyEl.style.display = shown ? 'none' : '';
    if (countEl) countEl.textContent = 'показано: ' + shown + ' из ' + total;
  }

  var filters = document.getElementById('dir-filters');
  if (filters) filters.addEventListener('click', function (e) {
    var chip = e.target.closest('.chip');
    if (!chip) return;
    var f = chip.dataset.f, v = chip.dataset.v;
    state[f] = v;
    document.querySelectorAll('.chip[data-f="' + f + '"]').forEach(function (c) {
      c.classList.toggle('active', c === chip);
    });
    apply();
  });
  var search = document.getElementById('dir-search');
  if (search) search.addEventListener('input', function (e) { state.q = e.target.value; apply(); });
  apply();
})();
</script>
{% endblock %}
