{% extends "_layout.html.j2" %}
{% block title %}{{ line.title }} — {{ site.title }}{% endblock %}
{% block description %}{{ line.title }} — описание железнодорожной линии и её раздельных пунктов.{% endblock %}
{% block canonical_path %}line-{{ line.id }}.html{% endblock %}
{% set active = 'railmap' %}
{% block head_extra %}<script type="application/ld+json">{{ jsonld_article | tojson }}</script>{% endblock %}

{% block main %}
<section class="page-head">
  <div class="wrap">
    <div class="breadcrumb"><a href="index.html">Главная</a> / <a href="railmap.html">Схема</a> / {{ line.kind }}</div>
    <div class="eyebrow">{{ line.kind }}</div>
    <h1>{{ line.title | nbsp }}</h1>
  </div>
</section>

<section class="content">
  <div class="wrap-narrow">
    <div id="line-body">{{ line.body | rich }}</div>
    <div class="rule-star"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l9 9-9 9-9-9z"/></svg></div>
    <a class="btn btn-ghost" href="railmap.html">← Схема линий</a>
  </div>
</section>
{% endblock %}
