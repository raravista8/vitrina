{% extends "_layout.html.j2" %}
{% block title %}{{ station.name }} — {{ site.title }}{% endblock %}
{% block description %}{{ station.kind }} {{ station.name }} {{ station.road }} железной дороги: схема путевого развития, справка, фотографии и история.{% endblock %}
{% block canonical_path %}{{ station.slug }}{% endblock %}
{% set active = 'railmap' %}
{% block head_extra %}<script type="application/ld+json">{{ jsonld_article | tojson }}</script>{% endblock %}

{% block main %}
<section class="page-head">
  <div class="wrap">
    <div class="breadcrumb"><a href="index.html">Главная</a> / <a href="railmap.html">Схема</a> / {{ station.road }} / {{ station.name }}</div>
    <div class="eyebrow">{{ station.kind }} · {{ station.road }} ж.д.</div>
    <h1>{{ station.name }}</h1>
    <p class="ph-sub">{{ station.line | nbsp }}</p>
  </div>
</section>

<section class="content">
  <div class="wrap">
    <div class="station-grid">
      <div>
        <div class="eyebrow green" style="margin-bottom:12px">Схема путевого развития</div>
        <div class="map-frame">
          <div class="map-canvas" style="aspect-ratio:16/7" id="st-scheme">
            <svg viewBox="0 0 1000 280" preserveAspectRatio="xMidYMid meet" style="width:100%;height:100%">
              <g stroke="#1f3d2b" stroke-width="3" fill="none">
                <path d="M40 140 H960"/>
                <path d="M180 140 C240 140 240 90 320 90 H720 C800 90 800 140 860 140"/>
                <path d="M180 140 C240 140 240 190 320 190 H600 C680 190 680 140 740 140"/>
              </g>
              <g fill="#b5552f"><circle cx="180" cy="140" r="5"/><circle cx="320" cy="90" r="5"/><circle cx="740" cy="140" r="5"/><circle cx="860" cy="140" r="5"/></g>
              <g fill="#847c6d" font-family="JetBrains Mono, monospace" font-size="15">
                <text x="40" y="125">I</text><text x="330" y="78">II</text><text x="330" y="210">3</text>
              </g>
            </svg>
            <div style="position:absolute;bottom:8px;right:12px;font-family:var(--f-mono);font-size:11px;color:var(--ink-4)">схема · упрощённо</div>
          </div>
        </div>

        <div class="eyebrow green" style="margin:28px 0 12px">Фотографии</div>
        <div class="photo-row" id="st-photos">
          {% for src in station.photos %}
          {% if src %}<figure class="ph-thumb"><img src="{{ src }}" alt="{{ station.name }}" loading="lazy" onerror="this.parentElement.classList.add('empty');this.remove();"></figure>
          {% else %}<figure class="ph-thumb empty"><span>фото {{ loop.index }}</span></figure>
          {% endif %}
          {% endfor %}
        </div>

        <div class="eyebrow green" style="margin:28px 0 12px">История</div>
        <div id="st-history">
          {% if station.history %}{{ station.history | rich }}{% else %}<p class="dim">Подробная историческая справка для этого пункта готовится.</p>{% endif %}
        </div>
      </div>

      <aside>
        <div class="eyebrow" style="margin-bottom:12px">Справка</div>
        <div class="spec" id="st-spec">
          {% for k, v in station.spec %}<div class="sp-k">{{ k }}</div><div class="sp-v">{{ v }}</div>
          {% endfor %}
        </div>

        {% if station.neighbors and station.neighbors[0] %}
        <div class="neighbor" id="st-neighbors">
          <div class="nb-row">
            <span class="nb-arrow">←</span>
            <div><div class="nb-lbl">по перегону</div><div class="nb-name">{{ station.neighbors[0] }}</div></div>
            <div style="flex:1;text-align:right"><div class="nb-lbl">по перегону</div><div class="nb-name">{{ station.neighbors[1] }}</div></div>
            <span class="nb-arrow">→</span>
          </div>
        </div>
        {% endif %}

        <div class="eyebrow" style="margin:26px 0 12px">Связанные документы</div>
        <ul class="doc-mini" id="st-docs">
          {% for org, num, d in station.docs %}
          <li><a href="docs.html"><span class="dm-num">{{ num }}</span> <span class="dm-org">{{ org }}</span><span class="dm-date mono">{{ d }}</span></a></li>
          {% else %}
          <li class="dm-empty">документы не привязаны</li>
          {% endfor %}
        </ul>
      </aside>
    </div>
  </div>
</section>
{% endblock %}
