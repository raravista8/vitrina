{#-
   Customer site v2.1 — booking-page upgrade.

   STATUS: ACTIVE PRODUCTION TEMPLATE (Phase 9c switchover).
     Replaces brochure-page v2 layout. Spec:
     `CLAUDE_CODE_TZ_customer_v2.1.md` (816 строк).
     Legacy template сохранён как `index.html.j2.legacy` на случай
     emergency rollback (revert PR + `mv legacy → active`).

   Switchover history:
     • 9a (PR #86): HTML skeleton с 10 секциями + minimal inline CSS.
     • 9b (PR #87): CSS refinement — `components/booking.css` (926 lines),
       process icons partial, gallery carousel fallback, a11y.
     • 9c (this PR): AI prompt updates в `core/content/prompts/customer_site.j2`
       для нового data shape (site.hero.h1 / process / faq / etc).
       Plus actual switchover from `index.html.j2` (legacy) to this
       file.

   Canon reference: `/tmp/samosite-canon/screens-customer.jsx` + spec
   sections §2-§13. Each section header has a `<!-- §N: ... -->`
   comment pointing to spec.

   Jinja2 data contract — extended from v2:
     site.name, site.category, site.city
     site.phone, site.phone_e164, site.address, site.geo
     site.rating, site.reviews_count, site.review_source
     site.hero.h1, site.hero.sub, site.hero.photo_url, site.hero.caption
     site.years_experience, site.clients_served
     site.social_badges = [{platform, rating, count}, ...]
     services = [{name, desc, duration, price, price_hint?}]
     services_last_updated (ISO-8601)
     process = [{icon, title, body}]   # 4 fixed steps
     gallery = [{url, alt, srcset?}]   # ≥10 ideally
     reviews_curated = [{author, avatar_url?, rating, text, date_iso, source, is_top_pick}]
     about = {photo_url, bio, creds: [str], guarantees: [str]}
     faq = [{question, answer}]        # ≥8 ideally
     contact_url (POST /api/leads)
     captcha_client_key
     site_subdomain (footer watermark ref)
     year
-#}
<!DOCTYPE html>
<html lang="{{ site_locale[:2] if site_locale else 'ru' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ site.hero.h1 }} — {{ site.name }}</title>
  <meta name="description" content="{{ site.hero.sub | striptags | truncate(155) }}">
  <link rel="canonical" href="{{ site_url }}">

  {# Schema.org LocalBusiness — see legacy template for full JSON-LD. #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "{{ site.name }}",
    "telephone": "{{ site.phone_e164 }}",
    "address": "{{ site.address }}",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ site.rating }}",
      "reviewCount": "{{ site.reviews_count }}"
    }
  }
  </script>

  {# v2.1.3 Phase 9b — inline styles extracted to components/booking.css.
     Production deploy: copy file as static asset OR inline via Jinja
     include — see Phase 9c switchover plan. Для skeleton review здесь
     stub link path. #}
  <link rel="stylesheet" href="/static/booking.css">

  {# Webfonts — Onest + JetBrains Mono. Same Google Fonts subset used by
     landing (landing/app/globals.css line 1). Customer-sites prerender
     statically so font-display: swap matters больше чем performance —
     CSS file remains immutable. #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500&family=Onest:wght@400;500;600;700&display=swap">
</head>

{# Process icons macro — see components/process-icons.html.j2 for
   SVG definitions for calendar/pin/coffee/sparkles. #}
{%- from "components/process-icons.html.j2" import process_icon -%}
<body>

{# ─── §2 Sticky header ─────────────────────────────────────────────── #}
<header class="ss-header" data-section="sticky-header">
  <div class="ss-header__brand"><b>{{ site.name }}</b></div>
  <nav>
    <a href="#services">Услуги</a>
    <a href="#reviews">Отзывы</a>
    <a href="#about">О мастере</a>
    <a href="#book">Контакты</a>
  </nav>
  <div style="margin-left: auto; display: flex; gap: 12px; align-items: center;">
    <a class="ss-phone" href="tel:{{ site.phone_e164 }}">{{ site.phone }}</a>
    <a class="ss-btn ss-btn--primary" href="#book">Записаться</a>
  </div>
</header>

{# ─── §3 Hero ──────────────────────────────────────────────────────── #}
<section id="hero" class="ss-hero" data-section="hero">
  <div>
    <div class="ss-eyebrow">{{ site.category | upper }} · {{ site.city | upper }}</div>
    <h1>{{ site.hero.h1 }}</h1>
    <p class="ss-hero__sub">{{ site.hero.sub }}</p>
    <div class="ss-trust-pill">
      ★★★★★ <b>{{ "%.1f" | format(site.rating) }} ★</b>
      · {{ site.reviews_count }} отзывов на {{ site.review_source }}
    </div>
    <div class="ss-hero__ctas">
      <a class="ss-btn ss-btn--primary" href="#book">Записаться →</a>
      <a class="ss-btn ss-btn--outline" href="tel:{{ site.phone_e164 }}">📞 {{ site.phone }}</a>
    </div>
  </div>
  <div class="ss-hero__photo">
    <img src="{{ site.hero.photo_url }}" alt="{{ site.hero.caption }}"
         width="600" height="750" loading="eager" decoding="async">
    <div class="ss-hero__caption">
      <div class="ss-mono ss-upper">{{ site.hero.caption }}</div>
      <div><b>{{ site.address }}</b></div>
    </div>
  </div>
</section>

{# ─── §4 Social proof bar ──────────────────────────────────────────── #}
<section class="ss-social-bar" data-section="social-bar">
  <div class="ss-mono">
    НАС ВЫБРАЛИ <b>{{ site.clients_served }}+</b> ЧЕЛОВЕК ЗА {{ site.years_experience }} ЛЕТ
  </div>
  {% if site.social_badges %}
  <div class="ss-social-badges">
    {% for badge in site.social_badges %}
      <span class="ss-badge">
        {{ badge.platform }} · {{ "%.1f" | format(badge.rating) }} ★ ({{ badge.count }})
      </span>
    {% endfor %}
  </div>
  {% endif %}
</section>

{# ─── §5 Services cards ────────────────────────────────────────────── #}
<section id="services" data-section="services">
  <header>
    <div class="ss-eyebrow">УСЛУГИ И ЦЕНЫ</div>
    <h2>Что я делаю</h2>
    {% if services_last_updated %}
      <span class="ss-mono ss-faint">цены актуальны · обновлены {{ services_last_updated }}</span>
    {% endif %}
  </header>
  <div class="ss-services-grid">
    {% for sv in services %}
    <article class="ss-service-card{% if services|length is odd and loop.index == 1 %} ss-service-card--featured{% endif %}">
      <header>
        <h3>{{ sv.name }}</h3>
        <div class="ss-service-card__price">
          <div class="ss-mono"><b>{{ sv.price }}</b></div>
          {% if sv.price_hint %}<div class="ss-mono ss-faint">{{ sv.price_hint }}</div>{% endif %}
        </div>
      </header>
      <p>{{ sv.desc }}</p>
      <footer style="display:flex;gap:12px;justify-content:space-between;align-items:center;margin-top:auto;">
        {% if sv.duration %}<span class="ss-mono">⏱ {{ sv.duration }}</span>{% endif %}
        <a class="ss-btn ss-btn--soft" href="#book">Записаться →</a>
      </footer>
    </article>
    {% endfor %}
  </div>
</section>

{# ─── §6 Process ──────────────────────────────────────────────────── #}
<section class="ss-process" data-section="process">
  <header style="text-align:center;">
    <div class="ss-eyebrow">КАК БУДЕТ</div>
    <h2>От записи до результата — четыре шага</h2>
  </header>
  <div class="ss-process-grid">
    {% for step in process %}
    <div class="ss-process-step">
      <div class="ss-process-icon">{{ process_icon(step.icon) }}</div>
      <div class="ss-mono">ШАГ {{ loop.index }}</div>
      <h3>{{ step.title }}</h3>
      <p>{{ step.body }}</p>
    </div>
    {% endfor %}
  </div>
</section>

{# ─── §7 Gallery ──────────────────────────────────────────────────── #}
{# Phase 9b — carousel fallback на mobile если фото < 8 (masonry с pустыми
   ячейками выглядит хуже horizontal-scroll carousel'я). Desktop всегда
   masonry; mobile carousel включается через `.ss-gallery--carousel` class. #}
{% if gallery and gallery | length >= 4 %}
<section class="ss-gallery-wrap" data-section="gallery">
  <header style="display:flex;justify-content:space-between;align-items:baseline;">
    <h2>Наши работы</h2>
    <span class="ss-mono ss-faint">обновляется из источника еженедельно</span>
  </header>
  <div class="ss-gallery{% if gallery | length < 8 %} ss-gallery--carousel{% endif %}">
    {% for photo in gallery %}
      <img src="{{ photo.url }}" alt="{{ photo.alt | default('') }}"
           width="600" height="600" loading="lazy" decoding="async">
    {% endfor %}
  </div>
</section>
{% endif %}

{# ─── §8 Reviews ──────────────────────────────────────────────────── #}
{% if reviews_curated %}
<section id="reviews" data-section="reviews">
  <header style="display:flex;justify-content:space-between;align-items:baseline;">
    <h2>Что говорят клиенты</h2>
    <span class="ss-mono ss-faint">
      {{ "%.1f" | format(site.rating) }} ★ · {{ site.reviews_count }} отзывов на {{ site.review_source }}
    </span>
  </header>
  <div class="ss-reviews-grid">
    {% for rev in reviews_curated %}
    <article class="ss-review-card{% if rev.is_top_pick %} ss-review-card--top{% endif %}">
      <div class="ss-review-card__head">
        {% if rev.avatar_url %}
          <img class="ss-avatar" src="{{ rev.avatar_url }}" alt="" width="40" height="40">
        {% else %}
          <div class="ss-avatar ss-avatar--initials">{{ rev.author[0] | upper }}</div>
        {% endif %}
        <div>
          <div><b>{{ rev.author }}</b></div>
          <div class="ss-mono ss-faint">{{ "★" * (rev.rating | int) }} · {{ rev.source }} · {{ rev.date_iso }}</div>
        </div>
      </div>
      <blockquote>«{{ rev.text }}»</blockquote>
    </article>
    {% endfor %}
  </div>
  {# Mid-page CTA — критичный элемент v2.1 booking-page pattern. #}
  <div style="margin-top: 32px; text-align: center;">
    <a class="ss-btn ss-btn--primary" href="#book">Записаться →</a>
  </div>
</section>
{% endif %}

{# ─── §9 About / specialist ───────────────────────────────────────── #}
{% if about %}
<section id="about" data-section="about">
  <div class="ss-about">
    {% if about.photo_url %}
      <img src="{{ about.photo_url }}" alt="{{ site.name }}" width="320" height="400" loading="lazy">
    {% endif %}
    <div>
      <div class="ss-eyebrow">О МАСТЕРЕ</div>
      <h2>{{ site.name }}</h2>
      <p>{{ about.bio }}</p>
      {% if about.creds %}
        <ul class="ss-creds">
          {% for c in about.creds %}<li>{{ c }}</li>{% endfor %}
        </ul>
      {% endif %}
      {% if about.guarantees %}
        <div class="ss-guarantees">
          <h3>Гарантии</h3>
          <ul>
            {% for g in about.guarantees %}<li>{{ g }}</li>{% endfor %}
          </ul>
        </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# ─── §10 FAQ ─────────────────────────────────────────────────────── #}
{% if faq %}
<section class="ss-faq" data-section="faq">
  <header>
    <div class="ss-eyebrow">ВОПРОСЫ</div>
    <h2>Часто спрашивают</h2>
  </header>
  {% for qa in faq %}
    <details{% if loop.first %} open{% endif %}>
      <summary>{{ qa.question }}</summary>
      <p>{{ qa.answer }}</p>
    </details>
  {% endfor %}
</section>
{% endif %}

{# ─── §11 Final booking — form + map + contact ────────────────────── #}
<section id="book" class="ss-book" data-section="book">
  <div class="ss-book__form">
    <div class="ss-eyebrow">ЗАПИСЬ</div>
    <h2>Запишитесь</h2>
    <form action="{{ contact_url }}" method="post">
      <label>
        Имя
        <input type="text" name="name" required>
      </label>
      <label>
        Телефон или мессенджер
        <input type="text" name="phone" required placeholder="+7 921 123-45-67 или @username">
      </label>
      <label>
        Услуга
        <select name="service">
          <option value="">— выберите —</option>
          {% for sv in services %}<option value="{{ sv.name }}">{{ sv.name }}</option>{% endfor %}
        </select>
      </label>
      <label>
        Когда удобно?
        <input type="text" name="when" placeholder="например, завтра вечером">
      </label>
      <label>
        Сообщение (опционально)
        <textarea name="message" rows="3"></textarea>
      </label>
      {# Yandex SmartCaptcha (T5.2) — placeholder div, script in head не WIP. #}
      <div class="smart-captcha" data-sitekey="{{ captcha_client_key }}"></div>
      <button type="submit" class="ss-btn ss-btn--primary">Отправить заявку</button>
    </form>
    {# Messenger alternatives row #}
    <div class="ss-book__messengers">
      <a href="tel:{{ site.phone_e164 }}">📞 {{ site.phone }}</a>
      {% if site.telegram_username %}<a href="https://t.me/{{ site.telegram_username }}">✈️ Telegram</a>{% endif %}
      {% if site.whatsapp_phone %}<a href="https://wa.me/{{ site.whatsapp_phone }}">💬 WhatsApp</a>{% endif %}
    </div>
  </div>

  <div class="ss-book__contact">
    <h3>Где мы</h3>
    <p>{{ site.address }}</p>
    {% if site.geo and site.geo.lat and site.geo.lon %}
      {# Yandex Maps iframe — replaces gradient placeholder. #}
      <iframe
        src="https://yandex.ru/map-widget/v1/?ll={{ site.geo.lon }},{{ site.geo.lat }}&z=15&pt={{ site.geo.lon }},{{ site.geo.lat }}"
        width="100%" height="280" frameborder="0"
        loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    {% endif %}
    {% if site.opening_hours %}
      <h4>Время работы</h4>
      <ul>
        {% for h in site.opening_hours %}<li>{{ h.day }}: {{ h.hours }}</li>{% endfor %}
      </ul>
    {% endif %}
  </div>
</section>

{# ─── §12 Footer ──────────────────────────────────────────────────── #}
<footer data-section="footer">
  <div>© {{ year }} {{ site.name }} · {{ site.city }}</div>
  <div class="ss-mono ss-faint">
    Сделано на <a href="https://samosite.online?ref={{ site_subdomain }}">Самосайте</a>
  </div>
</footer>

{# ─── §13 Sticky mobile CTA ───────────────────────────────────────── #}
<div class="ss-sticky-mobile" data-section="sticky-mobile">
  <a class="ss-btn ss-btn--primary" href="#book" style="width:100%;text-align:center;">
    Записаться · {{ site.phone }}
  </a>
</div>

</body>
</html>
