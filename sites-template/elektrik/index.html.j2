<!doctype html>
<html lang="ru">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ site.seo.title }}</title>
<meta name="description" content="{{ site.seo.description }}" />
<link rel="canonical" href="{{ base_url }}/" />
<meta name="robots" content="index, follow" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="{{ site.brand_name }}" />
<meta property="og:locale" content="ru_RU" />
<meta property="og:title" content="{{ site.seo.title }}" />
<meta property="og:description" content="{{ site.seo.description }}" />
<meta property="og:url" content="{{ base_url }}/" />
<meta property="og:image" content="{{ base_url }}/{{ site.hero.photo }}" />
<meta name="twitter:card" content="summary_large_image" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=Golos+Text:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="styles.css" />
<script type="application/ld+json">{{ jsonld | tojson }}</script>
</head>
<body>

<!-- ============ HEADER ============ -->
<header class="site-header">
  <div class="wrap header-inner">
    <a class="brand" href="#top">
      <span class="brand-mark">
        <svg viewBox="0 0 24 24" fill="none"><path d="M13.5 2 4 13.5h6L9 22l9.5-12H12l1.5-8Z" fill="#fff"/></svg>
      </span>
      <span>
        <span class="brand-name">Электромонтаж<br>под ключ</span>
      </span>
    </a>

    <nav class="main-nav">
      <a href="#services">Услуги</a>
      <a href="#how">Как работаем</a>
      <a href="#why">Почему мы</a>
      <a href="#reviews">Отзывы</a>
    </nav>

    <div class="header-cta">
      <a class="header-phone" href="tel:{{ phone_tel }}">
        <span class="ph-num">{{ site.phone }}</span>
        <span class="ph-hours">{{ site.hours }}</span>
      </a>
      <button class="btn btn-primary" data-open-form>
        <svg viewBox="0 0 24 24" fill="none"><path d="M13.5 2 4 13.5h6L9 22l9.5-12H12l1.5-8Z" fill="currentColor"/></svg>
        Заказать
      </button>
      <button class="burger" id="burger" aria-label="Меню">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- mobile drawer -->
<div class="m-nav" id="mnav">
  <a href="#services">Услуги</a>
  <a href="#how">Как работаем</a>
  <a href="#why">Почему мы</a>
  <a href="#reviews">Отзывы</a>
  <a href="tel:{{ phone_tel }}">Позвонить · {{ site.phone }}</a>
  <button class="btn btn-primary" data-open-form>Оставить заявку</button>
</div>

<span id="top"></span>

<!-- ============ HERO ============ -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="wrap hero-inner">
    <div class="hero-text">
      <span class="eyebrow">{{ site.hero.eyebrow }}</span>
      <h1>{{ site.hero.h1_before }}<span class="hl">{{ site.hero.h1_hl }}</span>{{ site.hero.h1_after }}</h1>
      <p class="hero-lead">{{ site.hero.lead }}</p>

      <div class="hero-actions">
        <button class="btn btn-primary btn-lg" data-open-form>
          <svg viewBox="0 0 24 24" fill="none"><path d="M13.5 2 4 13.5h6L9 22l9.5-12H12l1.5-8Z" fill="currentColor"/></svg>
          Оставить заявку
        </button>
        <a class="btn btn-ghost btn-lg" href="tel:{{ phone_tel }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L16 13l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z" stroke-linejoin="round"/></svg>
          Позвонить
        </a>
      </div>

      <div class="hero-trust">
        {% for t in site.hero.trust %}
        <div class="trust-item">
          <span class="ti-num">{{ t.num }}{% if t.star %}<span class="star">★</span>{% endif %}</span>
          <span class="ti-label">{{ t.label }}</span>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-photo">
        <img src="{{ site.hero.photo }}" alt="{{ site.hero.photo_alt }}"
             onerror="this.style.display='none';this.nextElementSibling.style.display='grid';" />
        <div class="ph" style="display:none">фото работ</div>
      </div>
    </div>
  </div>
</section>

<!-- ============ PROMO ============ -->
<div class="promo">
  <div class="wrap promo-inner">
    <div class="promo-badge">{{ site.promo.badge }}</div>
    <div class="promo-text">
      <h3>{{ site.promo.h3 }}</h3>
      <p>{{ site.promo.text_before }}<b>{{ site.promo.text_bold }}</b>{{ site.promo.text_after }}</p>
    </div>
    <button class="btn btn-primary" data-open-form>Получить расчёт</button>
  </div>
</div>

<!-- ============ SERVICES ============ -->
<section class="block" id="services">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.services.eyebrow }}</span>
      <h2>{{ site.services.h2 }}</h2>
      <p>{{ site.services.sub }}</p>
    </div>

    <div class="services-grid">
      {% for s in site.services['items'] %}
      <article class="service-card">
        <span class="service-ico">{{ service_icon(s.icon) }}</span>
        <h3>{{ s.title }}</h3>
        <p>{{ s.body }}</p>
        <div class="service-foot">
          <span class="service-price">{{ s.price }}<small>{{ s.price_note }}</small></span>
        </div>
      </article>
      {% endfor %}
    </div>

    <div class="price-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01M11 12h1v4h1" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {{ site.services.note }}
    </div>
    <div style="margin-top:34px">
      <button class="btn btn-primary btn-lg" data-open-form>
        <svg viewBox="0 0 24 24" fill="none"><path d="M13.5 2 4 13.5h6L9 22l9.5-12H12l1.5-8Z" fill="currentColor"/></svg>
        {{ site.services.cta }}
      </button>
    </div>
  </div>
</section>

<!-- ============ HOW ============ -->
<section class="block alt" id="how">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.how.eyebrow }}</span>
      <h2>{{ site.how.h2 }}</h2>
      <p>{{ site.how.sub }}</p>
    </div>

    <div class="steps">
      {% for st in site.how.steps %}
      <div class="step{% if st.free %} free{% endif %}">
        <span class="step-num">{{ st.num }}</span>
        <h3>{{ st.title }}</h3>
        <p>{{ st.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ============ WHY ============ -->
<section class="block" id="why">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.why.eyebrow }}</span>
      <h2>{{ site.why.h2 }}</h2>
    </div>

    <div class="why-grid">
      {% for w in site.why['items'] %}
      <div class="why-item"><span class="why-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12l4 4 10-10" stroke-linecap="round" stroke-linejoin="round"/></svg></span><div><h3>{{ w.title }}</h3><p>{{ w.body }}</p></div></div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ============ GALLERY ============ -->
<section class="block alt" id="works">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.works.eyebrow }}</span>
      <h2>{{ site.works.h2 }}</h2>
    </div>
    <div class="gallery" id="gallery"></div>
  </div>
</section>

<!-- ============ REVIEWS ============ -->
<section class="block" id="reviews">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.reviews.eyebrow }}</span>
      <h2>{{ site.reviews.h2 }}</h2>
    </div>

    <div class="reviews-top">
      <div>
        <div class="rt-score">{{ site.reviews.score }}</div>
        <div class="rt-stars">★★★★★</div>
      </div>
      <div class="rt-divider"></div>
      <div>
        <div class="rt-meta"><b>{{ site.reviews.meta_count }}</b> {{ site.reviews.meta_count_tail }}</div>
        <div class="rt-meta">{{ site.reviews.meta_since }}</div>
      </div>
      <div class="rt-divider"></div>
      <div class="rt-dist">
        {% for d in site.reviews.dist %}
        <div class="rt-row">{{ d.star }} <span class="bar"><i style="width:{{ d.pct }}%"></i></span> {{ d.count }}</div>
        {% endfor %}
      </div>
    </div>

    <div class="reviews-grid">
      {% for r in site.reviews['items'] %}
      <article class="review">
        <div class="r-stars">★★★★★</div>
        <p>{{ r.text }}</p>
        <div class="r-foot"><span class="r-ava">{{ r.ava }}</span><div><div class="r-name">{{ r.name }}</div><div class="r-svc">{{ r.svc }}</div></div></div>
      </article>
      {% endfor %}
    </div>

    <div class="reviews-foot">
      <a href="{{ site.avito_url }}" target="_blank" rel="noopener">{{ site.reviews.footer_link }}</a>
    </div>
  </div>
</section>

<!-- ============ CTA STRIP ============ -->
<section class="cta-strip">
  <div class="wrap cta-inner">
    <h2>{{ site.cta.h2 }}</h2>
    <div>
      <div class="cta-side">
        <button class="btn btn-dark btn-lg" data-open-form>
          <svg viewBox="0 0 24 24" fill="none"><path d="M13.5 2 4 13.5h6L9 22l9.5-12H12l1.5-8Z" fill="currentColor"/></svg>
          Оставить заявку
        </button>
        <a class="btn btn-ghost btn-lg" href="tel:{{ phone_tel }}" style="border-color:rgba(22,23,28,.3)">Позвонить</a>
      </div>
      <div class="cta-note">{{ site.cta.note }}</div>
    </div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<footer class="footer" id="contacts">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <span class="brand">
          <span class="brand-mark"><svg viewBox="0 0 24 24" fill="none"><path d="M13.5 2 4 13.5h6L9 22l9.5-12H12l1.5-8Z" fill="#fff"/></svg></span>
          <span class="brand-name" style="white-space:nowrap">{{ site.brand_name }}</span>
        </span>
        <p>{{ site.footer.about }}</p>
      </div>
      <div>
        <h4>Услуги</h4>
        <ul>
          {% for s in site.footer.services %}<li>{{ s }}</li>
          {% endfor %}
        </ul>
      </div>
      <div>
        <h4>Контакты</h4>
        <ul>
          <li><a class="f-phone" href="tel:{{ phone_tel }}">{{ site.phone }}</a></li>
          <li>{{ site.hours_short }}</li>
          <li>{{ site.region }}</li>
          <li><a href="{{ site.avito_url }}" target="_blank" rel="noopener">Профиль на Авито →</a></li>
        </ul>
        <button class="btn btn-primary" data-open-form style="margin-top:20px">Оставить заявку</button>
      </div>
    </div>
    <div class="footer-base">
      <span>{{ site.brand_name }} · {{ site.region }}</span>
      <a class="made-badge" href="https://samosite.online" target="_blank" rel="noopener">
        <span class="mb-mark">С</span>
        Сделано на Самосайт
      </a>
    </div>
  </div>
</footer>

<!-- ============ MODAL: форма заявки ============ -->
<div class="modal-root" id="modal" aria-hidden="true">
  <div class="modal-backdrop" data-close-form></div>
  <div class="modal-card" role="dialog" aria-modal="true" aria-label="Форма заявки">
    <div class="hazard"></div>
    <div class="modal-body" id="modalBody">
      <div class="modal-head">
        <div>
          <h2>Оставить заявку</h2>
          <p>Перезвоним в течение ~30 минут, бесплатно проконсультируем и сориентируем по стоимости.</p>
        </div>
        <button class="modal-close" data-close-form aria-label="Закрыть">✕</button>
      </div>

      <form id="orderForm" novalidate>
        <div class="field-row">
          <div class="field" data-validate="name">
            <label for="f-name">Имя <span class="req">*</span></label>
            <input type="text" id="f-name" name="name" placeholder="Как к вам обращаться" required />
            <div class="field-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01" stroke-linecap="round"/></svg><span>Укажите, как к вам обращаться</span></div>
          </div>
          <div class="field" data-validate="phone">
            <label for="f-phone">Телефон <span class="req">*</span></label>
            <input type="tel" id="f-phone" name="phone" placeholder="+7 ___ ___-__-__" required />
            <div class="field-error"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01" stroke-linecap="round"/></svg><span>Введите корректный номер телефона</span></div>
          </div>
        </div>

        <div class="field">
          <label>Тип объекта</label>
          <div class="segmented">
            {% for o in site.form.object_types %}<label><input type="radio" name="object" value="{{ o }}"{% if loop.first %} checked{% endif %} /><span>{{ o }}</span></label>{% endfor %}
          </div>
        </div>

        <div class="field">
          <label for="f-service">Какая нужна услуга</label>
          <select id="f-service" name="service">
            {% for s in site.form.services %}<option>{{ s }}</option>{% endfor %}
          </select>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="f-addr">Адрес / район</label>
            <input type="text" id="f-addr" name="address" placeholder="СПб или Ленобласть" />
          </div>
          <div class="field">
            <label for="f-time">Удобное время для звонка</label>
            <select id="f-time" name="calltime">
              {% for t in site.form.call_times %}<option>{{ t }}</option>{% endfor %}
            </select>
          </div>
        </div>

        <div class="field">
          <label for="f-comment">Комментарий / описание задачи</label>
          <textarea id="f-comment" name="comment" placeholder="Коротко опишите, что нужно сделать"></textarea>
        </div>

        <div class="field">
          <label>Фото объекта (необязательно)</label>
          <label class="dropzone" id="dropzone" for="f-photos">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 16V4m0 0L8 8m4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke-linecap="round"/></svg>
            <div class="dz-main">Перетащите фото сюда или нажмите</div>
            <div class="dz-sub">JPG, PNG · до 5 файлов</div>
            <input type="file" id="f-photos" name="photos" accept="image/*" multiple hidden />
          </label>
          <div class="dz-previews" id="dzPreviews"></div>
        </div>

        <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" />

        <label class="consent">
          <input type="checkbox" id="f-consent" checked />
          <span>Нажимая кнопку, я соглашаюсь на обработку персональных данных и принимаю условия <a href="/privacy" target="_blank" rel="noopener">политики конфиденциальности</a>.</span>
        </label>

        <button type="submit" id="submitBtn" class="btn btn-primary btn-lg btn-block">
          <svg viewBox="0 0 24 24" fill="none"><path d="M13.5 2 4 13.5h6L9 22l9.5-12H12l1.5-8Z" fill="currentColor"/></svg>
          <span class="btn-label">Отправить заявку</span>
        </button>
      </form>
    </div>
  </div>
</div>

<!-- ============ LIGHTBOX ============ -->
<div class="lightbox" id="lightbox">
  <button class="lb-close" id="lbClose" aria-label="Закрыть">✕</button>
  <button class="lb-nav lb-prev" id="lbPrev" aria-label="Назад">‹</button>
  <img id="lbImg" src="" alt="" />
  <button class="lb-nav lb-next" id="lbNext" aria-label="Вперёд">›</button>
</div>

<script>
window.__SITE_ID = "{{ site.site_id }}";
window.__PHONE = "{{ site.phone }}";
window.__PHOTOS = {{ site.works.photos | tojson }};
</script>
<script src="app.js"></script>
</body>
</html>
