  <path d="M7 4 c 0 1 1 1 1 2 s -1 1 -1 2"/>
  <path d="M11 4 c 0 1 1 1 1 2 s -1 1 -1 2"/>
</svg>
{%- elif kind == "sparkles" -%}
<svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
  <path d="M12 3 L13.4 8.2 L18.6 9 L13.4 9.8 L12 15 L10.6 9.8 L5.4 9 L10.6 8.2 Z"/>
