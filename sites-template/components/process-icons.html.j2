{#-
   Process icons partial — 4 fixed SVG glyphs для §6 «Как будет».

   Source: `/tmp/samosite-canon/screens-customer.jsx :: ProcessIcon`.

   Usage в `index.html.j2.v21`:
     {% from "components/process-icons.html.j2" import process_icon %}
     ...
     <div class="ss-process-icon">{{ process_icon(step.icon) }}</div>

   `step.icon` enum:
     - "calendar" — для шага «Записываетесь»
     - "pin"      — для шага «Приходите»
     - "coffee"   — для шага «Делаем услугу»
     - "sparkles" — для шага «Уходите красивыми»

   Fallback (unknown icon) — пустой div.
-#}

{%- macro process_icon(kind) -%}
{%- if kind == "calendar" -%}
<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <rect x="3" y="5" width="18" height="16" rx="2"/>
  <path d="M8 3v4M16 3v4M3 10h18"/>
</svg>
{%- elif kind == "pin" -%}
<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M12 2 C 7 2, 4 6, 4 10 C 4 16, 12 22, 12 22 C 12 22, 20 16, 20 10 C 20 6, 17 2, 12 2 Z"/>
  <circle cx="12" cy="10" r="3"/>
</svg>
{%- elif kind == "coffee" -%}
<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M4 8h13v5a5 5 0 0 1-5 5H9 a5 5 0 0 1-5-5z"/>
